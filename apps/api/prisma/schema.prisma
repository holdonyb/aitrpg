generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(uuid())
  email             String               @unique
  displayName       String
  campaigns         Campaign[]
  spectatorComments SpectatorComment[]
  shareLinks        ShareLink[]          @relation("ShareLinkCreator")
  emailCodes        EmailCodeChallenge[]
  reviewReports     ReviewReport[]
  reviewRuns        ReviewRun[]
  createdAt         DateTime             @default(now())
}

model Campaign {
  id            String      @id @default(uuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id])
  title         String
  pitch         String
  worldTemplate String
  tone          String
  rooms         Room[]
  characters    Character[]
  createdAt     DateTime    @default(now())
}

model Character {
  id             String         @id @default(uuid())
  campaignId     String
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name           String
  ancestry       String
  className      String
  background     String
  personality    String
  controlledBy   String
  portraitAssets PortraitAsset[]
}

model Room {
  id                      String             @id @default(uuid())
  campaignId              String
  campaign                Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title                   String
  description             String
  status                  String
  createdBy               String
  visibility              String             @default("PRIVATE")
  passwordHash            String?
  spectatorCommentEnabled Boolean            @default(false)
  events                  StoryEvent[]
  mediaJobs               MediaJob[]
  spectatorComments       SpectatorComment[]
  createdAt               DateTime           @default(now())
}

model StoryEvent {
  id          String   @id @default(uuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  characterId String?
  type        String
  content     String
  createdAt   DateTime @default(now())
}

model MediaJob {
  id        String   @id @default(uuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  type      String
  title     String
  prompt    String
  status    String
  createdAt DateTime @default(now())
}

model PortraitAsset {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  prompt      String
  imageUrl    String
  status      String    @default("succeeded")
  createdAt   DateTime  @default(now())
}

model ShareLink {
  id        String   @id @default(uuid())
  targetType String
  targetId  String
  token     String   @unique
  createdBy String
  creator   User     @relation("ShareLinkCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@unique([targetType, targetId])
}

model SpectatorComment {
  id              String   @id @default(uuid())
  roomId          String
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDisplayName String
  content         String
  createdAt       DateTime @default(now())
}

model EmailCodeChallenge {
  id        String   @id @default(uuid())
  email     String
  code      String
  inviteCodeId String?
  inviteCode InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)
  expiresAt DateTime
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([email])
}

model InviteCode {
  id          String               @id @default(uuid())
  code        String               @unique
  status      String               @default("active")
  usageLimit  Int
  usedCount   Int                  @default(0)
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  emailCodes  EmailCodeChallenge[]
}

model ReviewReport {
  id            String   @id @default(uuid())
  createdBy     String
  creator       User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  scope         String
  reviewerLabel String
  status        String
  targetType    String   @default("SYSTEM")
  targetId      String?
  resolutionStatus String @default("OPEN")
  summary       String
  findings      String
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  reviewRunId   String?
  reviewRun     ReviewRun? @relation(fields: [reviewRunId], references: [id], onDelete: SetNull)
}

model ReviewRun {
  id            String   @id @default(uuid())
  createdBy     String
  creator       User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  scope         String
  reviewerLabel String
  targetType    String   @default("SYSTEM")
  targetId      String?
  brief         String
  status        String   @default("queued")
  summary       String?
  createdAt     DateTime @default(now())
  completedAt   DateTime?
  reports       ReviewReport[]
}
